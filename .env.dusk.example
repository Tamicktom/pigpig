APP_NAME=Laravel
APP_ENV=dusk.local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# Optional: system Chrome / ChromeDriver (Docker `app` image installs Chromium under /usr/bin)
# DUSK_CHROME_BINARY=/usr/bin/chromium
# DUSK_CHROMEDRIVER_PATH=/usr/bin/chromedriver

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/dusk.sqlite

BROADCAST_CONNECTION=log
CACHE_STORE=array
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

MAIL_MAILER=array

VITE_APP_NAME=Laravel

# Dusk must load built assets (public/build/manifest.json), not the Vite dev server. If you run
# `npm run dev` locally, delete public/hot before Dusk or use `composer run test:dusk` (it removes hot).
