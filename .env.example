APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# Docker Compose: PHP app serves on FORWARD_APP_PORT (default 8000). Use service hostnames below when running Artisan inside containers.
# When using Docker Compose, set APP_URL to the host URL you open in the browser (include FORWARD_APP_PORT if not 8000), e.g. http://localhost:8001
APP_URL=http://localhost:8000

# If you run PHP on the host while Postgres/Redis run in Docker only, use 127.0.0.1 for DB_HOST/REDIS_HOST and published ports (5432, 6379).
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=pigpig
DB_USERNAME=pigpig
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Redis avoids the database `cache` table (queue restart signal). Required for the worker before `php artisan cache:table` + migrate.
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mailpit (docker-compose service "mailpit"). Web UI: http://localhost:8025
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Mailpit HTTP API (integration tests). From the host use 127.0.0.1; inside Docker use http://mailpit:8025.
MAILPIT_API_URL=http://127.0.0.1:8025
# Optional overrides when tests send real SMTP (see composer.json script "test:mailpit")
# MAILPIT_SMTP_HOST=127.0.0.1
# MAILPIT_SMTP_PORT=1025
RUN_MAILPIT_TESTS=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Optional: enable Vite file polling when bind mounts miss fs events (Docker Compose sets this on the vite service automatically)
# VITE_USE_FILE_POLLING=true
# Optional: browser port for HMR when FORWARD_VITE_PORT maps the host to a different port than 5173 (Docker Compose sets this from FORWARD_VITE_PORT)
# VITE_HMR_CLIENT_PORT=5173

# Optional: override published host ports (docker-compose.yml)
# FORWARD_APP_PORT=8000
# FORWARD_DB_PORT=5432
# FORWARD_REDIS_PORT=6379
# FORWARD_VITE_PORT=5173
# FORWARD_MAILPIT_UI_PORT=8025
# FORWARD_MAILPIT_SMTP_PORT=1025

# Resend email service
RESEND_API_KEY=
